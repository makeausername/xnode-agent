services:
  xnode:
    image: {{ .Image }}
    container_name: xnode
    network_mode: host
    restart: unless-stopped
    volumes:
      - ./data:/var/lib/xnode
      - ./logs:/var/log/xnode
    environment:
      PANEL_URL: "${PANEL_URL}"
      NODE_ID: "${NODE_ID}"
      NODE_DOMAIN: "${NODE_DOMAIN}"
      ENROLL_TOKEN: "${ENROLL_TOKEN}"
      DATA_DIR: "/var/lib/xnode"
      LOG_DIR: "/var/log/xnode"
      XRAY_BIN: "/usr/local/bin/xray"
      TZ: "{{ .Timezone }}"
